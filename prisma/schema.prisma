// Postgres (Neon) — same schema in local dev and on Vercel.
//
// Enum-typed columns (role, type, exportStage, verification, category) are stored as
// validated strings (checked in app code against lib/taxonomy.ts), and list columns
// (sectors, targetMarkets, …) as JSON-encoded text via lib/serialize.ts. These were
// originally SQLite accommodations; they work unchanged on Postgres, so the move is a
// provider swap rather than a data-model rewrite.
//
// DATABASE_URL = pooled connection (pgbouncer) used by the app at runtime.
// DIRECT_URL    = direct connection used by Prisma Migrate (migrate deploy/dev).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  role          String // EXPORTER | IMPORTER | ADMIN
  locale        String    @default("en")
  emailVerified DateTime?
  company       Company?
  createdAt     DateTime  @default(now())
}

model Company {
  id            String           @id @default(cuid())
  owner         User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId       String           @unique
  type          String // EXPORTER | IMPORTER
  nameEn        String
  nameAr        String?
  email         String
  phone         String?
  website       String?
  logoUrl       String?
  descriptionEn String?
  descriptionAr String?
  countryIso2   String
  verification  String           @default("UNVERIFIED")
  isDraft       Boolean          @default(false)
  exporter        ExporterProfile?
  importer        ImporterProfile?
  products        Product[]
  readinessScores ReadinessScore[]
  demandRequests  DemandRequest[]
  createdAt       DateTime         @default(now())

  @@index([type, verification])
  @@index([type, isDraft])
}

// Phase 4 — importer-posted "requests for imports". Browsable in the public import-requests
// directory; created and managed by importers from their dashboard.
model DemandRequest {
  id                String   @id @default(cuid())
  importer          Company  @relation(fields: [importerId], references: [id], onDelete: Cascade)
  importerId        String
  category          String // Industry
  title             String
  description       String
  quantity          String?
  targetCountryIso2 String?
  status            String   @default("OPEN") // OPEN | CLOSED
  createdAt         DateTime @default(now())

  @@index([category, status])
  @@index([importerId])
}

// Phase 4 — export-readiness scoring. The integer score + breakdown come from the
// deterministic rubric (lib/readiness/rubric.ts, the source of truth); narrative is
// either a deterministic explanation or a Claude-generated one (source = rules | ai).
model ReadinessScore {
  id                String   @id @default(cuid())
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId         String
  targetCountryIso2 String
  score             Int
  band              String // low | medium | high
  breakdown         String // JSON of the scored dimensions
  topGaps           String   @default("[]") // JSON string[]
  narrative         String?
  source            String   @default("rules") // rules | ai
  model             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([companyId, targetCountryIso2])
}

model ExporterProfile {
  companyId        String  @id
  company          Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  governorate      String
  sectors          String  @default("[]") // JSON string[]
  exportStage      String
  certifications   String  @default("[]") // JSON string[]
  yearEstablished  Int?
  employeeBucket   String?
  capacityNote     String?
  hasExportLicense Boolean @default(false)
  currentMarkets   String  @default("[]") // JSON string[] (iso2)
  targetMarkets    String  @default("[]") // JSON string[] (iso2)
}

model ImporterProfile {
  companyId            String  @id
  company              Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  industries           String  @default("[]") // JSON string[]
  categoriesOfInterest String  @default("[]") // JSON string[]
  orderVolume          String?
}

model Product {
  id          String  @id @default(cuid())
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId   String
  nameEn      String
  nameAr      String?
  category    String
  description String?

  @@index([companyId])
}
