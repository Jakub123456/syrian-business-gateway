# Copy to .env.local (Next) and .env (Prisma CLI). Both need DATABASE_URL + DIRECT_URL.

# Postgres (Neon). Two URLs from the Neon dashboard:
#  - DATABASE_URL = POOLED connection (host contains "-pooler"), used by the app at runtime.
#    Append ?sslmode=require&pgbouncer=true&connection_limit=1
#  - DIRECT_URL   = DIRECT connection (no "-pooler"), used by Prisma Migrate.
#    Append ?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DB?sslmode=require"

# Session signing secret (required). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""

# Anthropic Claude — optional. Without it, readiness scoring falls back to rule-based.
ANTHROPIC_API_KEY=""

# The exporter map uses OpenStreetMap (Leaflet) — no API key required.
# Optional model override (defaults to claude-opus-4-8)
READINESS_MODEL=""
