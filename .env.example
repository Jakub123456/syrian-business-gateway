# Copy to .env.local (Next) — also keep a .env for the Prisma CLI. Both need these two.

# Dev database (SQLite). Prod target is Postgres: postgresql://user:pass@host:5432/sbg
DATABASE_URL="file:./dev.db"

# Session signing secret (required). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=""

# Anthropic Claude (readiness scoring, matching, dev plans) — Phase 4
ANTHROPIC_API_KEY=""
